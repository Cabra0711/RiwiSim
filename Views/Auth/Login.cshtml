<div class="min-h-screen w-full flex bg-gray-50/50">
  <div class="w-full xl:w-2/3 flex flex-col justify-center items-center p-6 md:p-12 z-10">
    <div class="w-full max-w-md">

      <div class="flex flex-col items-center mb-10 text-center">
        <div class="w-16 h-16 bg-blue-600 rounded-xl flex items-center justify-center shadow-lg mb-4">
          <span class="material-symbols-outlined text-white text-[32px]">speed</span>
        </div>
        <h1 class="text-3xl md:text-4xl font-extrabold text-blue-600 tracking-tight">
          Velocity Logistics
        </h1>
        <p class="text-sm md:text-base text-gray-500 mt-2 font-medium">
          Eficiencia en cada kilómetro.
        </p>
      </div>

      <div class="bg-white p-8 rounded-xl shadow-[0_4px_24px_rgba(0,0,0,0.04)] border border-gray-100 transition-all duration-300 hover:shadow-[0_12px_32px_rgba(0,0,0,0.08)]">
        <h2 class="text-xl md:text-2xl font-bold text-gray-900 mb-6">Ingresar</h2>

        <div id="errorMessage" class="hidden mb-4 p-3 bg-red-50 border border-red-200 text-red-600 text-sm rounded-lg font-medium"></div>

        <form id="loginForm" class="space-y-5">
          <div class="space-y-1.5">
            <label class="text-xs md:text-sm font-semibold text-gray-600 ml-1" for="email">Correo Electrónico</label>
            <div class="relative group">
              <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 group-focus-within:text-blue-600 transition-colors">mail</span>
              <input class="w-full pl-11 pr-4 py-3 bg-gray-50 border border-gray-200 rounded-lg text-sm md:text-base text-gray-900 focus:outline-none focus:ring-2 focus:ring-blue-600/10 focus:border-blue-600 transition-all placeholder:text-gray-400" id="email" placeholder="nombre@ejemplo.com" type="email" required/>
            </div>
          </div>

          <div class="space-y-1.5">
            <div class="flex justify-between items-center px-1">
              <label class="text-xs md:text-sm font-semibold text-gray-600" for="password">Contraseña</label>
              <a class="text-xs text-blue-500 hover:underline" href="#">¿Olvidaste tu contraseña?</a>
            </div>
            <div class="relative group">
              <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 group-focus-within:text-blue-600 transition-colors">lock</span>
              <input class="w-full pl-11 pr-12 py-3 bg-gray-50 border border-gray-200 rounded-lg text-sm md:text-base text-gray-900 focus:outline-none focus:ring-2 focus:ring-blue-600/10 focus:border-blue-600 transition-all placeholder:text-gray-400" id="password" placeholder="••••••••" type="password" required/>
              <button id="togglePassword" class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-700 transition-colors" type="button" aria-label="Mostrar contraseña">
                <span class="material-symbols-outlined text-[20px] select-none">visibility</span>
              </button>
            </div>
          </div>

          <button class="w-full bg-blue-600 text-white py-3.5 rounded-lg font-bold text-base shadow-md hover:bg-blue-700 active:scale-[0.99] transition-all flex items-center justify-center gap-2 mt-2" type="submit">
            <span>Ingresar</span>
            <span class="material-symbols-outlined text-[20px]">arrow_forward</span>
          </button>
        </form>

        <div class="relative my-8 flex items-center">
          <div class="flex-grow border-t border-gray-200"></div>
          <span class="flex-shrink mx-4 text-[10px] font-bold text-gray-400 uppercase tracking-widest">o continúa con</span>
          <div class="flex-grow border-t border-gray-200"></div>
        </div>

        <div class="grid grid-cols-2 gap-3">
          <button class="flex items-center justify-center gap-2 py-2.5 border border-gray-200 rounded-lg hover:bg-gray-50 transition-colors active:scale-95">
            <svg class="w-5 h-5" viewbox="0 0 24 24"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"></path><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"></path><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"></path><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"></path></svg>
            <span class="text-sm font-semibold text-gray-700">Google</span>
          </button>
          <button class="flex items-center justify-center gap-2 py-2.5 border border-gray-200 rounded-lg hover:bg-gray-50 transition-colors active:scale-95">
            <svg class="w-5 h-5 text-[#1877F2]" fill="currentColor" viewbox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"></path></svg>
            <span class="text-sm font-semibold text-gray-700">Facebook</span>
          </button>
        </div>
      </div>

      <div class="mt-8 space-y-4">
        <p class="text-[10px] font-bold text-center text-gray-400 uppercase tracking-widest mb-2">¿No tienes una cuenta?</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <a class="group block p-4 bg-white border border-gray-200 rounded-xl hover:border-gray-400 hover:shadow-md transition-all" href="@Url.Action("RegisterClientView", "Auth")">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 bg-gray-100 text-gray-700 rounded-lg flex items-center justify-center group-hover:bg-200 transition-colors">
                <span class="material-symbols-outlined">person</span>
              </div>
              <div class="flex flex-col">
                <span class="text-xs font-medium text-gray-500">Registrarse como</span>
                <span class="text-sm font-bold text-gray-800">Cliente</span>
              </div>
            </div>
          </a>

          <a class="group block p-4 bg-white border border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all" href="@Url.Action("RegisterDriverView", "Auth")">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 bg-blue-50 text-blue-600 rounded-lg flex items-center justify-center group-hover:bg-blue-100 transition-colors">
                <span class="material-symbols-outlined">directions_car</span>
              </div>
              <div class="flex flex-col">
                <span class="text-xs font-medium text-blue-500">Registrarse como</span>
                <span class="text-sm font-bold text-blue-600">Conductor</span>
              </div>
            </div>
          </a>
        </div>
      </div>

      <footer class="mt-12 text-center">
        <p class="text-xs md:text-sm text-gray-500">
          Al continuar, aceptas nuestros
          <a class="text-blue-600 font-semibold hover:underline" href="#">Términos de Servicio</a>
          y
          <a class="text-blue-600 font-semibold hover:underline" href="#">Política de Privacidad</a>.
        </p>
      </footer>

    </div>
  </div>

  <div class="hidden xl:block xl:w-1/3 relative overflow-hidden bg-slate-950 border-l border-gray-800">
    <div class="absolute inset-0 bg-cover bg-center [mask-image:linear-gradient(to_left,black,transparent)] opacity-25 mix-blend-lighten scale-110" style="background-image: url('https://images.unsplash.com/photo-1524661135339-9140b00787e3?auto=format&fit=crop&w=1000&q=80')"></div>
    <div class="absolute inset-0 bg-gradient-to-tr from-blue-950/70 via-slate-950/90 to-transparent"></div>

    <div class="absolute inset-0 p-8 flex flex-col justify-between z-20">
      <div class="flex justify-end">
        <div class="bg-slate-900/80 backdrop-blur-md border border-slate-700/50 rounded-full px-4 py-1.5 flex items-center gap-2 shadow-xl animate-pulse">
          <span class="w-2 h-2 rounded-full bg-emerald-500"></span>
          <span class="text-xs font-bold text-slate-300 tracking-wide uppercase">Cobertura: Aburrá Sur Activo</span>
        </div>
      </div>

      <div class="space-y-4 mb-10 max-w-sm self-start">
        <div class="bg-slate-950/60 backdrop-blur-lg border border-slate-800 p-4 rounded-xl shadow-2xl">
          <div class="flex items-center gap-3 mb-2">
            <div class="w-8 h-8 rounded-lg bg-emerald-500/10 flex items-center justify-center text-emerald-400">
              <span class="material-symbols-outlined text-[18px]">local_taxi</span>
            </div>
            <div>
              <p class="text-xs font-semibold text-slate-400">Oferta promedio actual</p>
              <p class="text-lg font-black text-white">$14.500 COP</p>
            </div>
          </div>
          <p class="text-[11px] text-slate-500 font-medium">Lógica de negociación directa activa en el entorno de pruebas.</p>
        </div>

        <div class="relative w-full h-24 bg-slate-900/30 rounded-xl border border-slate-800/40 overflow-hidden">
          <div class="absolute top-1/3 left-1/4 flex flex-col items-center">
            <span class="material-symbols-outlined text-emerald-400 text-[20px] animate-bounce">location_on</span>
            <span class="text-[9px] font-bold bg-slate-950 text-emerald-400 px-1 rounded border border-emerald-500/20">Envigado</span>
          </div>
          <div class="absolute bottom-1/4 right-1/3 flex flex-col items-center">
            <span class="material-symbols-outlined text-blue-400 text-[20px]">navigation</span>
            <span class="text-[9px] font-bold bg-slate-950 text-blue-400 px-1 rounded border border-blue-500/20">Ruta Activa</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  // Micro-interactions for focus
  const inputs = document.querySelectorAll('input');
  inputs.forEach(input => {
    input.addEventListener('focus', () => {
      input.parentElement.parentElement.classList.add('scale-[1.01]');
    });
    input.addEventListener('blur', () => {
      input.parentElement.parentElement.classList.remove('scale-[1.01]');
    });
  });

  // Toggle password icon visibility
  document.addEventListener('DOMContentLoaded', () => {
    const passwordInput = document.getElementById('password');
    const toggleButton = document.getElementById('togglePassword');
    const iconSpan = toggleButton.querySelector('.material-symbols-outlined');

    toggleButton.addEventListener('click', () => {
      const isPassword = passwordInput.type === 'password';
      passwordInput.type = isPassword ? 'text' : 'password';
      iconSpan.textContent = isPassword ? 'visibility_off' : 'visibility';
    });
  });

  // Petición limpia al Login
  document.getElementById('loginForm').addEventListener('submit', async (e) => {
    e.preventDefault();

    const email = document.getElementById('email').value;
    const password = document.getElementById('password').value;
    const errorDiv = document.getElementById('errorMessage');

    errorDiv.classList.add('hidden');

    try {
      const response = await fetch('/api/auth/login', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({ email, password })
      });

      const result = await response.json();

      if (!response.ok || !result.success) {
        errorDiv.textContent = result.message || 'Error en las credenciales, parce.';
        errorDiv.classList.remove('hidden');
        return;
      }

      // Se guarda solo por persistencia local de datos/sesión
      localStorage.setItem('token', result.data.token);

    } catch (error) {
      errorDiv.textContent = 'Hubo un problema de conexión con el servidor.';
      errorDiv.classList.remove('hidden');
    }
  });
</script>